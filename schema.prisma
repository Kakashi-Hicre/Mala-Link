generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────

enum ApplicationType {
  NATIONAL_ID
  PASSPORT
  DRIVING_LICENCE
}

enum ApplicationStatus {
  PENDING
  PROCESSING
  PRINTING
  READY
  COLLECTED
  REJECTED
}

enum NotificationChannel {
  SMS
  EMAIL
  IN_APP
}

enum AgencyName {
  NRB
  DRTSS
  IMMIGRATION
}

enum UserRole {
  CITIZEN
  AGENCY_STAFF
  ADMIN
}

enum CardStatus {
  ACTIVE
  EXPIRED
  LOST
  SUSPENDED
}

enum Sex {
  MALE
  FEMALE
}

// ─── Models ───────────────────────────────────────────────────

model Citizen {
  id           String   @id @default(uuid())
  fullName     String
  email        String   @unique
  phone        String   @unique
  passwordHash String
  role         UserRole @default(CITIZEN)
  nationalIdNo String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  applications  Application[]
  notifications Notification[]
}

model Agency {
  id   String     @id @default(uuid())
  name AgencyName @unique

  applications Application[]
  staff        AgencyStaff[]
}

model AgencyStaff {
  id           String   @id @default(uuid())
  fullName     String
  email        String   @unique
  passwordHash String
  role         UserRole @default(AGENCY_STAFF)
  agencyId     String
  agency       Agency   @relation(fields: [agencyId], references: [id])
  createdAt    DateTime @default(now())
}

model Application {
  id        String            @id @default(uuid())
  type      ApplicationType
  status    ApplicationStatus @default(PENDING)
  notes     String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  citizenId String
  citizen   Citizen @relation(fields: [citizenId], references: [id])

  agencyId String
  agency   Agency  @relation(fields: [agencyId], references: [id])

  documents Document[]
  idCard    IDCard?
  form      ApplicationForm?   // ← NEW: one form per application
}

model ApplicationForm {
  id            String      @id @default(uuid())
  applicationId String      @unique
  application   Application @relation(fields: [applicationId], references: [id])

  // ── Personal Information ──────────────────────────────
  fullName        String
  dateOfBirth     DateTime
  sex             Sex
  placeOfBirth    String
  district        String
  nationality     String    @default("Malawian")
  physicalAddress String

  // ── Contact ───────────────────────────────────────────
  phone           String
  email           String?

  // ── Next of Kin ───────────────────────────────────────
  nextOfKinName     String
  nextOfKinPhone    String
  nextOfKinRelation String

  // ── Document-specific fields (optional) ───────────────
  existingLicenceNo  String?   // Driving Licence renewals
  previousPassportNo String?   // Passport renewals

  // ── Staff Review ──────────────────────────────────────
  isVerified   Boolean   @default(false)
  verifiedAt   DateTime?
  verifiedById String?   // AgencyStaff id who verified it

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Document {
  id            String      @id @default(uuid())
  fileName      String
  fileUrl       String
  fileType      String
  uploadedAt    DateTime    @default(now())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id])
}

model IDCard {
  id         String     @id @default(uuid())
  cardNumber String     @unique

  // ── Card Holder Info ──────────────────────────────────
  holderName  String
  sex         Sex
  dateOfBirth DateTime
  expiryDate  DateTime
  cardStatus  CardStatus @default(ACTIVE)

  issuedAt  DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Optional — null for manually registered cards (no application)
  applicationId String?      @unique
  application   Application? @relation(fields: [applicationId], references: [id])

  createdAt DateTime @default(now())
}

model Notification {
  id        String              @id @default(uuid())
  channel   NotificationChannel
  message   String
  isRead    Boolean             @default(false)
  sentAt    DateTime            @default(now())
  citizenId String
  citizen   Citizen             @relation(fields: [citizenId], references: [id])
}
